<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
  <dict>
    <key>Label</key>
    <string>__LAUNCH_AGENT_LABEL__</string>

    <key>ProgramArguments</key>
    <array>
      <string>__CLI_PATH__</string>
      <string>run-autoreconnect</string>
    </array>

    <key>RunAtLoad</key>
    <true/>

    <key>StartInterval</key>
    <integer>__AUTORECONNECT_INTERVAL__</integer>

    <key>StandardOutPath</key>
    <string>__LOG_DIR__/autoreconnect.launchd.out</string>
    <key>StandardErrorPath</key>
    <string>__LOG_DIR__/autoreconnect.launchd.err</string>
  </dict>
</plist>
