# gtvpn config file
# Copy this file to ~/.config/gtvpn/config.env and edit the values you need.
# This file is sourced by bash. Keep values shell-safe.

# Required for password auth. Not a secret, but do not commit your real value.
VPN_USER="your_gt_account"

# Gatech defaults.
VPN_PORTAL="vpn.gatech.edu"
VPN_PROTOCOL="gp"
VPN_GATEWAY_LABEL="DC Gateway"
VPN_OS="mac-intel"

# Optional: pin the VPN certificate fingerprint if you want stricter server validation.
# Example: pin-sha256:abcdef...
VPN_SERVERCERT=""

# Georgia Tech reachability defaults.
OPENCONNECT_RESOLVES="vpn.gatech.edu:143.215.254.43 dc-ext-gw.vpn.gatech.edu:128.61.110.1"
GT_NET_ROUTES="128.61.0.0/16 130.207.0.0/16 143.215.0.0/16"
GT_DNS_HOSTS="130.207.244.244 130.207.244.251"
GT_SCOPED_RESOLVER_DOMAINS="gatech.edu cc.gatech.edu pace.gatech.edu vpn.gatech.edu"
LOCAL_DNS_FALLBACK="75.75.75.75"

# Connection mode:
#   password -> Keychain password autofill + prompt/keychain/static MFA
#   browser  -> external browser auth for SSO/passkey flows if the portal supports it
AUTH_MODE="password"

# Password storage lives in macOS Keychain.
PASSWORD_KEYCHAIN_SERVICE="gtvpn-openconnect"
PASSWORD_KEYCHAIN_ACCOUNT="$VPN_USER"

# MFA handling for password mode.
#   static   -> use MFA_RESPONSES and rotate on Duo 512 responses
#   prompt   -> prompt every time a Challenge appears
#   keychain -> read a value from Keychain service/account below
#   command  -> run MFA_COMMAND and use stdout as the response
#   none     -> send an empty response
MFA_MODE="static"
MFA_RESPONSES="push1 push2 phone1 phone2"
MFA_KEYCHAIN_SERVICE="gtvpn-mfa"
MFA_KEYCHAIN_ACCOUNT="$VPN_USER"
MFA_COMMAND=""

# Browser/passkey auth settings.
# If AUTH_MODE=browser and EXTERNAL_BROWSER_CMD is non-empty, it is executed with
# GTVPN_BROWSER_TARGET exported to the URL or file OpenConnect wants opened.
# Otherwise EXTERNAL_BROWSER_APP is used with `open -a`.
EXTERNAL_BROWSER_APP=""
EXTERNAL_BROWSER_CMD=""

# Optional: store the macOS admin password in Keychain for one-click SwiftBar
# connect/disconnect without an additional prompt. Leave unset if you prefer the
# AppleScript password dialog each time.
SUDO_PASSWORD_KEYCHAIN_SERVICE="gtvpn-sudo"
SUDO_PASSWORD_KEYCHAIN_ACCOUNT="$USER"

# Optional extra OpenConnect flags.
# Keep this space-delimited. Avoid arguments that themselves require spaces.
OPENCONNECT_EXTRA_ARGS=""

# Local install locations.
STATE_DIR="$HOME/Library/Application Support/gtvpn"
LOG_DIR="$HOME/Library/Logs/gtvpn"
SWIFTBAR_PLUGIN_DIR="$HOME/Documents/SwiftBarPlugins"
AUTORECONNECT_INTERVAL="600"
